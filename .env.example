# ─── Supabase ───────────────────────────────────────
# Supabase 프로젝트 설정 > API에서 확인
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...  # service_role_key (비공개, anon key 아님)

# ─── Amplitude ──────────────────────────────────────
# Amplitude > Settings > Projects > API Key
AMPLITUDE_API_KEY=your_amplitude_api_key

# ─── Mixpanel ───────────────────────────────────────
# Mixpanel > Settings > Project Settings
MIXPANEL_PROJECT_TOKEN=your_project_token
MIXPANEL_PROJECT_ID=your_project_id

# Mixpanel > Settings > Service Accounts > 새로 생성
MIXPANEL_SERVICE_ACCOUNT_USERNAME=your_sa_username
MIXPANEL_SERVICE_ACCOUNT_SECRET=your_sa_secret
